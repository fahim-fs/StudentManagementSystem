<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="frontend.controller.AttendanceController">

    <!-- Overall Summary Card -->
    <VBox spacing="0"
          style="-fx-background-color: white;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);
                 -fx-padding: 24 28 20 28;">

        <Label text="Attendance Summary"
               style="-fx-font-size: 18px; -fx-font-weight: bold;
                      -fx-text-fill: #2c3e50; -fx-padding: 0 0 16 0;" />

        <!-- 3 summary boxes -->
        <HBox spacing="20">

            <!-- Overall % -->
            <VBox alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #f4fffe;
                         -fx-background-radius: 12;
                         -fx-border-color: #b2ebf2;
                         -fx-border-radius: 12;
                         -fx-border-width: 1;
                         -fx-padding: 20;">
                <Label text="Overall Attendance"
                       style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                <Label fx:id="overallPctLabel" text="—"
                       style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                <Label fx:id="overallStatusLabel" text=""
                       style="-fx-font-size: 13px; -fx-text-fill: #27ae60; -fx-font-weight: bold;" />
            </VBox>

            <!-- Total Classes Held -->
            <VBox alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #f8f9fa;
                         -fx-background-radius: 12;
                         -fx-border-color: #dee2e6;
                         -fx-border-radius: 12;
                         -fx-border-width: 1;
                         -fx-padding: 20;">
                <Label text="Total Classes Held"
                       style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                <Label fx:id="totalHeldLabel" text="—"
                       style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <Label text="All Courses"
                       style="-fx-font-size: 11px; -fx-text-fill: #aaa;" />
            </VBox>

            <!-- Total Attended -->
            <VBox alignment="CENTER" spacing="6" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #f8f9fa;
                         -fx-background-radius: 12;
                         -fx-border-color: #dee2e6;
                         -fx-border-radius: 12;
                         -fx-border-width: 1;
                         -fx-padding: 20;">
                <Label text="Total Attended"
                       style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                <Label fx:id="totalAttendedLabel" text="—"
                       style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #2a9d8f;" />
                <Label text="All Courses"
                       style="-fx-font-size: 11px; -fx-text-fill: #aaa;" />
            </VBox>

        </HBox>
    </VBox>

    <Separator />

    <!-- Course-wise list -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background: transparent; -fx-background-color: transparent;">
        <content>
            <VBox fx:id="courseAttendanceList" spacing="12"
                  style="-fx-padding: 20 28;" />
        </content>
    </ScrollPane>

</VBox>
