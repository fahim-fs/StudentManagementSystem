<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="718.0" prefWidth="965.0"
            style="-fx-background-color: linear-gradient(to bottom right, #e0f7fa, #b2ebf2);"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="frontend.controller.RegisterController">

    <children>

        <VBox layoutX="80.0" layoutY="40.0" prefWidth="805.0" spacing="0"
              style="-fx-background-color: white;                      -fx-background-radius: 16;                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 6);                      -fx-padding: 35 40 35 40;">

            <Label style="-fx-font-size: 26px;                                                  -fx-font-weight: bold;                                                  -fx-text-fill: #2c3e50;                                                  -fx-padding: 0 0 5 0;"
                   text="Create Account"/>
            <Label style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d; -fx-padding: 0 0 20 0;"
                   text="Please fill in the details below to register."/>

            <HBox spacing="30" style="-fx-padding: 0 0 15 0;">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;" text="First Name"/>
                    <TextField fx:id="f_name" promptText="Enter first name"
                               style="-fx-pref-height: 36px;                                       -fx-background-radius: 8;                                       -fx-border-radius: 8;                                       -fx-border-color: #ccc;                                       -fx-border-width: 1;                                       -fx-padding: 0 10;                                       -fx-font-size: 13px;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;" text="Last Name"/>
                    <TextField fx:id="l_name" promptText="Enter last name"
                               style="-fx-pref-height: 36px;                                       -fx-background-radius: 8;                                       -fx-border-radius: 8;                                       -fx-border-color: #ccc;                                       -fx-border-width: 1;                                       -fx-padding: 0 10;                                       -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <HBox spacing="30" style="-fx-padding: 0 0 15 0;">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;"
                           text="Father's Name"/>
                    <TextField fx:id="father_name" promptText="Enter father's name"
                               style="-fx-pref-height: 36px;                                       -fx-background-radius: 8;                                       -fx-border-radius: 8;                                       -fx-border-color: #ccc;                                       -fx-border-width: 1;                                       -fx-padding: 0 10;                                       -fx-font-size: 13px;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;"
                           text="Mother's Name"/>
                    <TextField fx:id="mother_name" promptText="Enter mother's name"
                               style="-fx-pref-height: 36px;                                       -fx-background-radius: 8;                                       -fx-border-radius: 8;                                       -fx-border-color: #ccc;                                       -fx-border-width: 1;                                       -fx-padding: 0 10;                                       -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <HBox spacing="30" style="-fx-padding: 0 0 15 0;">
                <VBox prefHeight="60.0" prefWidth="166.0" spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;"
                           text="Date of Birth"/>
                    <DatePicker fx:id="date_birth" promptText="DD/MM/YYYY"
                                style="-fx-pref-height: 36px;                                        -fx-background-radius: 8;                                        -fx-border-radius: 8;                                        -fx-border-color: #ccc;                                        -fx-border-width: 1;                                        -fx-font-size: 13px;                                        -fx-pref-width: 9999;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;" text="Phone No."/>
                    <TextField fx:id="phone_number" promptText="+8801*********"
                               style="-fx-pref-height: 36px;                                       -fx-background-radius: 8;                                       -fx-border-radius: 8;                                       -fx-border-color: #ccc;                                       -fx-border-width: 1;                                       -fx-padding: 0 10;                                       -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <VBox spacing="5" style="-fx-padding: 0 0 15 0;">
                <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;" text="Address"/>
                <TextField fx:id="address" promptText="House#, Road#, City"
                           style="-fx-pref-height: 36px;                                   -fx-background-radius: 8;                                   -fx-border-radius: 8;                                   -fx-border-color: #ccc;                                   -fx-border-width: 1;                                   -fx-padding: 0 10;                                   -fx-font-size: 13px;"/>
            </VBox>

            <HBox spacing="30" style="-fx-padding: 0 0 15 0;">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;" text="Gender"/>
                    <HBox spacing="20" style="-fx-padding: 8 0 0 0;">
                        <RadioButton fx:id="g_male" style="-fx-font-size: 13px; -fx-text-fill: #444;" text="Male">
                            <toggleGroup>
                                <ToggleGroup fx:id="genderGroup"/>
                            </toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="g_female" style="-fx-font-size: 13px; -fx-text-fill: #444;" text="Female"
                                     toggleGroup="$genderGroup"/>
                    </HBox>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;" text="Session"/>
                    <TextField fx:id="session" prefWidth="131.0" promptText="e.g. 2024-25"
                               style="-fx-pref-height: 36px;                                       -fx-background-radius: 8;                                       -fx-border-radius: 8;                                       -fx-border-color: #ccc;                                       -fx-border-width: 1;                                       -fx-padding: 0 10;                                       -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <HBox spacing="30" style="-fx-padding: 0 0 15 0;">
                <VBox prefHeight="60.0" prefWidth="173.0" spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;" text="Department"/>
                    <ComboBox fx:id="department" editable="true" promptText="Select Department"
                              style="-fx-pref-height: 36px;                                      -fx-background-radius: 8;                                      -fx-border-radius: 8;                                      -fx-border-color: #ccc;                                      -fx-border-width: 1;                                      -fx-font-size: 13px;                                      -fx-pref-width: 9999;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;" text="Username"/>
                    <TextField fx:id="username" promptText="Choose a username"
                               style="-fx-pref-height: 36px;                                       -fx-background-radius: 8;                                       -fx-border-radius: 8;                                       -fx-border-color: #ccc;                                       -fx-border-width: 1;                                       -fx-padding: 0 10;                                       -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <HBox spacing="30" style="-fx-padding: 0 0 10 0;">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;" text="Password"/>
                    <PasswordField fx:id="password" promptText="Enter password"
                                   style="-fx-pref-height: 36px;                                           -fx-background-radius: 8;                                           -fx-border-radius: 8;                                           -fx-border-color: #ccc;                                           -fx-border-width: 1;                                           -fx-padding: 0 10;                                           -fx-font-size: 13px;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-font-weight: bold;"
                           text="Confirm Password"/>
                    <PasswordField fx:id="confirm_password" promptText="Password must match"
                                   style="-fx-pref-height: 36px;                                           -fx-background-radius: 8;                                           -fx-border-radius: 8;                                           -fx-border-color: #ccc;                                           -fx-border-width: 1;                                           -fx-padding: 0 10;                                           -fx-font-size: 13px;"/>
                </VBox>
            </HBox>

            <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px; -fx-padding: 0 0 6 0;"
                   text=""/>

            <Button fx:id="registerBtn" onAction="#handleRegister"
                    style="-fx-background-color: #3498db;                            -fx-text-fill: white;                            -fx-font-size: 15px;                            -fx-font-weight: bold;                            -fx-pref-height: 42px;                            -fx-pref-width: 9999;                            -fx-background-radius: 10;                            -fx-cursor: hand;"
                    text="Create Account"/>

            <HBox alignment="CENTER" spacing="4" style="-fx-padding: 12 0 0 0;">
                <Label style="-fx-font-size: 13px; -fx-text-fill: #555;" text="Already have an account?"/>
                <Hyperlink fx:id="signInLink" onAction="#goToSignIn"
                           style="-fx-font-size: 13px; -fx-text-fill: #3498db; -fx-font-weight: bold; -fx-border-color: transparent;"
                           text="Sign in"/>
            </HBox>

        </VBox>

    </children>
</AnchorPane>
