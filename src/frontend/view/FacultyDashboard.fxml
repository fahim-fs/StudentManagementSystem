<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1100.0"
    style="-fx-background-color: linear-gradient(to bottom right, #e0f7fa, #b2ebf2);"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="frontend.controller.FacultyDashboardController">

    <children>
        <HBox prefHeight="720.0" prefWidth="1100.0"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

            <!-- ══ SIDEBAR ══════════════════════════════════════════════════ -->
            <VBox prefWidth="240.0" prefHeight="720.0" spacing="0"
                  style="-fx-background-color: #1a2e3b;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 3, 0);">

                <!-- Faculty Profile -->
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-padding: 28 16 20 16; -fx-background-color: #14242f;">
                    <Label text="🎓"
                           style="-fx-font-size: 36px;
                                  -fx-background-color: #2a9d8f;
                                  -fx-background-radius: 50;
                                  -fx-padding: 10 13;" />
                    <Label fx:id="facultyNameLabel" text="Faculty Name"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <Label text="Faculty"
                           style="-fx-font-size: 11px; -fx-text-fill: #a0b4bf;" />
                    <Label fx:id="departmentLabel" text="Department"
                           style="-fx-font-size: 11px; -fx-text-fill: #a0b4bf;" />
                </VBox>

                <!-- Nav -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background: transparent; -fx-background-color: transparent;">
                    <content>
                        <VBox spacing="2" style="-fx-padding: 10 8;">

                            <Button fx:id="btnHome" text="🏠   Home"
                                    onAction="#showHome" maxWidth="Infinity"
                                    style="-fx-background-color: #2a9d8f; -fx-text-fill: white;
                                           -fx-font-size: 13px; -fx-alignment: CENTER-LEFT;
                                           -fx-padding: 10 16; -fx-background-radius: 8; -fx-cursor: hand;" />

                            <Button fx:id="btnProfile" text="👤   My Profile"
                                    onAction="#showProfile" maxWidth="Infinity"
                                    style="-fx-background-color: transparent; -fx-text-fill: #cdd9e0;
                                           -fx-font-size: 13px; -fx-alignment: CENTER-LEFT;
                                           -fx-padding: 10 16; -fx-background-radius: 8; -fx-cursor: hand;" />

                            <Separator style="-fx-background-color: #2a3f4f;" />

                            <Button fx:id="btnAttendance" text="📅   Attendance Entry"
                                    onAction="#showAttendanceEntry" maxWidth="Infinity"
                                    style="-fx-background-color: transparent; -fx-text-fill: #cdd9e0;
                                           -fx-font-size: 13px; -fx-alignment: CENTER-LEFT;
                                           -fx-padding: 10 16; -fx-background-radius: 8; -fx-cursor: hand;" />

                            <Button fx:id="btnResults" text="📝   Results Entry"
                                    onAction="#showResultsEntry" maxWidth="Infinity"
                                    style="-fx-background-color: transparent; -fx-text-fill: #cdd9e0;
                                           -fx-font-size: 13px; -fx-alignment: CENTER-LEFT;
                                           -fx-padding: 10 16; -fx-background-radius: 8; -fx-cursor: hand;" />

                            <Separator style="-fx-background-color: #2a3f4f;" />

                            <Button fx:id="btnNotices" text="📢   Notices"
                                    maxWidth="Infinity" onAction="#showNotices"
                                    style="-fx-background-color: transparent; -fx-text-fill: #cdd9e0; -fx-font-size: 13px;
                                           -fx-alignment: CENTER-LEFT; -fx-padding: 10 16; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Button fx:id="btnStudentList" text="👥   Student List"
                                    onAction="#showStudentList" maxWidth="Infinity"
                                    style="-fx-background-color: transparent; -fx-text-fill: #cdd9e0;
                                           -fx-font-size: 13px; -fx-alignment: CENTER-LEFT;
                                           -fx-padding: 10 16; -fx-background-radius: 8; -fx-cursor: hand;" />

                        </VBox>
                    </content>
                </ScrollPane>

                <!-- Logout -->
                <VBox style="-fx-padding: 10 8 16 8;">
                    <Separator style="-fx-background-color: #2a3f4f;" />
                    <Button fx:id="btnLogout" text="🚪   Logout"
                            onAction="#handleLogout" maxWidth="Infinity"
                            style="-fx-background-color: #c0392b; -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-alignment: CENTER-LEFT;
                                   -fx-padding: 10 16; -fx-background-radius: 8; -fx-cursor: hand;" />
                </VBox>

            </VBox>

            <!-- ══ MAIN CONTENT ════════════════════════════════════════════ -->
            <VBox HBox.hgrow="ALWAYS" prefHeight="720.0" spacing="0">

                <!-- Top bar -->
                <HBox alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-padding: 14 28;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                    <Label fx:id="pageTitle" text="Home"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="Faculty Portal"
                           style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                </HBox>

                <!-- mainContentArea -->
                <VBox fx:id="mainContentArea" VBox.vgrow="ALWAYS">

                    <!-- HOME CONTENT -->
                    <VBox fx:id="homeContent" spacing="20" style="-fx-padding: 24;">

                        <Label text="Welcome to Faculty Portal"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

                        <HBox spacing="20">

                            <VBox HBox.hgrow="ALWAYS" spacing="6" alignment="CENTER_LEFT"
                                  style="-fx-background-color: white; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);
                                         -fx-padding: 20;">
                                <Label text="👥  My Students"
                                       style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                                <Label fx:id="totalStudentsLabel" text="—"
                                       style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                                <Label text="Enrolled in my courses"
                                       style="-fx-font-size: 11px; -fx-text-fill: #aaa;" />
                            </VBox>

                            <VBox HBox.hgrow="ALWAYS" spacing="6" alignment="CENTER_LEFT"
                                  style="-fx-background-color: white; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);
                                         -fx-padding: 20;">
                                <Label text="📚  My Courses"
                                       style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                                <Label fx:id="totalCoursesLabel" text="—"
                                       style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2a9d8f;" />
                                <Label text="Assigned by Admin"
                                       style="-fx-font-size: 11px; -fx-text-fill: #aaa;" />
                            </VBox>

                            <VBox HBox.hgrow="ALWAYS" spacing="8" alignment="TOP_LEFT"
                                  style="-fx-background-color: white; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);
                                         -fx-padding: 20;">
                                <Label text="Quick Guide"
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                <Label text="📅  Attendance Entry → Select your course → Enter data"
                                       style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                                <Label text="📝  Results Entry → CT / Quiz / Term Final marks"
                                       style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                                <Label text="👥  Student List → View students per your course"
                                       style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                                <Label text="👤  My Profile → Edit contact info / change password"
                                       style="-fx-font-size: 12px; -fx-text-fill: #555;" />
                            </VBox>

                        </HBox>
                    </VBox>
                    <!-- END HOME CONTENT -->

                </VBox>

            </VBox>

        </HBox>
    </children>
</AnchorPane>
