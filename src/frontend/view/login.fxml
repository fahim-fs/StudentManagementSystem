<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="718.0" prefWidth="965.0" style="-fx-background-color: linear-gradient(to bottom right, #e0f7fa, #b2ebf2);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="frontend.controller.LoginController">

    <children>

        <VBox alignment="CENTER" prefHeight="718.0" prefWidth="965.0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <VBox alignment="TOP_CENTER" maxWidth="460.0" spacing="0" style="-fx-background-color: white;                          -fx-background-radius: 16;                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 6);                          -fx-padding: 45 50 40 50;">

                <HBox alignment="CENTER" style="-fx-padding: 0 0 18 0;">
                    <Label style="-fx-font-size: 42px;                                   -fx-background-color: #e0f7fa;                                   -fx-background-radius: 50;                                   -fx-padding: 16 18;" text="🎓" />
                </HBox>

                <Label style="-fx-font-size: 26px;                               -fx-font-weight: bold;                               -fx-text-fill: #2c3e50;                               -fx-padding: 0 0 5 0;" text="Welcome Back!" />
                <Label style="-fx-font-size: 13px;                               -fx-text-fill: #7f8c8d;                               -fx-padding: 0 0 28 0;" text="Sign in to your account" />

                <VBox spacing="5" style="-fx-padding: 0 0 15 0;">
                    <Label style="-fx-font-size: 13px;                                   -fx-text-fill: #555;                                   -fx-font-weight: bold;" text="Username" />
                    <TextField fx:id="username" promptText="Enter your username" style="-fx-pref-height: 38px;                                       -fx-background-radius: 8;                                       -fx-border-radius: 8;                                       -fx-border-color: #ccc;                                       -fx-border-width: 1;                                       -fx-padding: 0 10;                                       -fx-font-size: 13px;" />
                </VBox>

                <VBox spacing="5" style="-fx-padding: 0 0 6 0;">
                    <Label style="-fx-font-size: 13px;                                   -fx-text-fill: #555;                                   -fx-font-weight: bold;" text="Password" />
                    <PasswordField fx:id="password" promptText="Enter your password" style="-fx-pref-height: 38px;                                           -fx-background-radius: 8;                                           -fx-border-radius: 8;                                           -fx-border-color: #ccc;                                           -fx-border-width: 1;                                           -fx-padding: 0 10;                                           -fx-font-size: 13px;" />
                </VBox>

                <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 0 18 0;">
                    <Hyperlink fx:id="forgotLink" onAction="#handleForgotPassword" style="-fx-font-size: 12px;                                       -fx-text-fill: #3498db;                                       -fx-border-color: transparent;" text="Forgot password?" />
                </HBox>

                <Label fx:id="messageLabel" style="-fx-text-fill: #e74c3c;                               -fx-font-size: 12px;                               -fx-padding: 0 0 8 0;" text="" />

                <Button fx:id="loginBtn" onAction="#handleLogin" style="-fx-background-color: #3498db;                                -fx-text-fill: white;                                -fx-font-size: 15px;                                -fx-font-weight: bold;                                -fx-pref-height: 42px;                                -fx-pref-width: 9999;                                -fx-background-radius: 10;                                -fx-cursor: hand;" text="Sign In" />

                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 18 0 14 0;">
                    <Label style="-fx-text-fill: #aaa; -fx-font-size: 12px;" text="or" />
                </HBox>
                <HBox alignment="CENTER" spacing="4">
                    <Label style="-fx-font-size: 13px; -fx-text-fill: #555;" text="Don't have an account?" />
                    <Hyperlink fx:id="registerLink" onAction="#goToRegister" style="-fx-font-size: 13px;                                       -fx-text-fill: #3498db;                                       -fx-font-weight: bold;                                       -fx-border-color: transparent;" text="Register now" />
                </HBox>

            </VBox>
        </VBox>

    </children>
</AnchorPane>
