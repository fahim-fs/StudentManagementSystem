<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0"
      style="-fx-background-color: transparent;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="frontend.controller.CourseRegistrationController">

    <!-- Header bar -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-padding: 20 24 16 24;
                 -fx-background-color: white;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">

        <VBox spacing="3">
            <Label text="Course Registration"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
            <Label text="Select a level/term and add courses within the 20 credit limit."
                   style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <!-- Level/Term selector -->
        <ComboBox fx:id="levelTermDropdown" promptText="Select Level - Term"
                  style="-fx-pref-width: 200px;
                         -fx-pref-height: 36px;
                         -fx-background-radius: 8;
                         -fx-border-radius: 8;
                         -fx-border-color: #ccc;
                         -fx-font-size: 13px;" />

        <!-- Credit info -->
        <VBox alignment="CENTER_RIGHT" spacing="2">
            <Label fx:id="totalCreditLabel" text="Total: 0 / 20 credits"
                   style="-fx-font-size: 12px; -fx-text-fill: #2c3e50; -fx-font-weight: bold;" />
            <Label fx:id="remainingCreditLabel" text="Remaining: 20 credits"
                   style="-fx-font-size: 12px; -fx-text-fill: #27ae60; -fx-font-weight: bold;" />
        </VBox>

    </HBox>

    <!-- Message label -->
    <Label fx:id="messageLabel" text=""
           style="-fx-font-size: 12px; -fx-padding: 8 24 0 24;" />

    <!-- Main content -->
    <HBox spacing="16" VBox.vgrow="ALWAYS"
          style="-fx-padding: 16 24 24 24;">

        <!-- Available Courses -->
        <VBox HBox.hgrow="ALWAYS" spacing="10">
            <Label text="Available Courses"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
            <Separator />
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <content>
                    <VBox fx:id="availableCourseList" spacing="8"
                          style="-fx-padding: 4 0;" />
                </content>
            </ScrollPane>
        </VBox>

        <!-- Divider -->
        <Separator orientation="VERTICAL" />

        <!-- Registered Courses -->
        <VBox HBox.hgrow="ALWAYS" spacing="10">
            <Label text="Registered Courses"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
            <Separator />
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <content>
                    <VBox fx:id="registeredCourseList" spacing="8"
                          style="-fx-padding: 4 0;" />
                </content>
            </ScrollPane>
        </VBox>

    </HBox>

</VBox>
